{
  "name": "job-search-automation",
  "version": "1.0.0",
  "description": "Automate job evaluation against resume using AI",
  "main": "index.js",
  "scripts": {
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "cd ui && bun run dev",
    "dev": "bun run --parallel dev:server dev:client",
    "build": "cd ui && bun run build",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "googleapis": "^140.0.0",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "pdf-parse": "1.1.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "bun-types": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
